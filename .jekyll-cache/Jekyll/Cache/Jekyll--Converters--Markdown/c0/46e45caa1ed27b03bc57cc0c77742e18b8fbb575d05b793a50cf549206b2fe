<ul>
  <li>Board: 0, Player: 0, Time taken: 1.59</li>
  <li>Board: 0, Player: 1, Time taken: 1.58</li>
  <li>Board: 1, Player: 0, Time taken: 0.00117</li>
  <li>Board: 1, Player: 1, Time taken: 0.00103</li>
  <li>Board: 2, Player: 0, Time taken: 5.04</li>
  <li>Board: 2, Player: 1, Time taken: 4.94</li>
  <li>Board: 3, Player: 0, Time taken: 29.2</li>
  <li>Board: 3, Player: 1, Time taken: 32.0</li>
